# Vibe-Check Environment Variables

# Spotify API Credentials (Required for Spotipy)
# Get these from https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here

# Genius API for Lyrics (Optional, uses simple fallback if not provided)
# Get this from https://docs.genius.com/
GENIUS_ACCESS_TOKEN=your_genius_access_token_here

# Database Configuration
# Default is SQLite for easy local dev. To use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/vibecheck
DATABASE_URL=sqlite:///vibecheck.db
